---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const locales = ['en', 'fr'];
  const posts = await getCollection('posts');

  return locales.flatMap((locale) =>
    posts.map((post) => ({
      params: { locale, slug: post.id },
      props: { post, locale },
    }))
  );
}

const { post, locale } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={post.data.title}
  description={`Read the post: ${post.data.title}`}
  locale={locale}
>
  <article class="mx-auto max-w-3xl px-4 py-16 md:py-24">
    <header class="mb-10">
      <h1 class="font-heading text-4xl font-bold text-navy md:text-5xl">
        {post.data.title}
      </h1>
    </header>
    <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-navy prose-a:text-teal-text">
      <Content />
    </div>
  </article>
</BaseLayout>
